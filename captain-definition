{
    "schemaVersion": 2,
    "dockerfileLines": [
        "# ========================================",
        "# Stage 1: Dependencies",
        "# ========================================",
        "FROM library/node:lts-alpine3.19 AS deps",
        "RUN apk add --no-cache libc6-compat",
        "RUN npm install -g pnpm@10",
        "WORKDIR /app",
        "COPY package.json pnpm-lock.yaml ./",
        "# Skip puppeteer's bundled-Chromium download — the runner uses system chromium.",
        "ENV PUPPETEER_SKIP_DOWNLOAD=true",
        "RUN pnpm install --frozen-lockfile",
        "",
        "# ========================================",
        "# Stage 2: Builder",
        "# ========================================",
        "FROM library/node:lts-alpine3.19 AS builder",
        "RUN npm install -g pnpm@10",
        "WORKDIR /app",
        "COPY --from=deps /app/node_modules ./node_modules",
        "COPY . .",
        "",
        "# Forge has NO NEXT_PUBLIC_* vars — nothing secret is baked into the build.",
        "# All runtime config (DATABASE_URL, FORGE_SECRET_KEY, ANTHROPIC_API_KEY,",
        "# MMAGENT_AUTH_TOKEN, FORGE_ADMIN_*, FORGE_WORKSPACE_ROOT, …) is injected by",
        "# CapRover as container env vars at runtime, never at build.",
        "ENV NEXT_TELEMETRY_DISABLED=1",
        "ENV PUPPETEER_SKIP_DOWNLOAD=true",
        "RUN pnpm run build",
        "",
        "# ========================================",
        "# Stage 3: Production Runner",
        "# ========================================",
        "FROM library/node:lts-alpine3.19 AS runner",
        "# git → team-repo clones (src/git); chromium + fonts → PDF export (puppeteer).",
        "RUN apk add --no-cache libc6-compat tzdata git chromium nss freetype harfbuzz ca-certificates ttf-freefont font-noto-emoji",
        "WORKDIR /app",
        "",
        "ENV NODE_ENV=production",
        "ENV PORT=80",
        "ENV HOSTNAME=0.0.0.0",
        "ENV TZ=Asia/Singapore",
        "ENV NEXT_TELEMETRY_DISABLED=1",
        "# Use the system Chromium for puppeteer; FORGE_PDF_NO_SANDBOX defaults true.",
        "ENV PUPPETEER_SKIP_DOWNLOAD=true",
        "ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser",
        "# On-disk roots for cloned repos + generated exports (mount a CapRover",
        "# persistent volume here if clones/exports must survive redeploys).",
        "ENV FORGE_WORKSPACE_ROOT=/app/.forge-workspace",
        "ENV FORGE_EXPORT_ROOT=/app/.forge-exports",
        "# Behind CapRover's nginx → trust the proxy and require secure cookies.",
        "ENV FORGE_TRUST_PROXY=1",
        "ENV FORGE_COOKIE_SECURE=1",
        "",
        "# Non-root runtime user.",
        "RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs",
        "",
        "# Next.js standalone output + static assets + public.",
        "COPY --from=builder /app/public ./public",
        "COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./",
        "COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static",
        "# Mock-demo mode (MOCK_BACKEND=1): plan.ts reads this .md from disk at runtime.",
        "COPY --from=builder --chown=nextjs:nodejs /app/src/mock/data ./src/mock/data",
        "",
        "# Writable working dirs owned by the runtime user (.mock-db = mock-mode store).",
        "RUN mkdir -p /app/.forge-workspace /app/.forge-exports /app/.mock-db && chown -R nextjs:nodejs /app/.forge-workspace /app/.forge-exports /app/.mock-db",
        "",
        "USER nextjs",
        "EXPOSE 80",
        "",
        "CMD [\"node\", \"server.js\"]"
    ]
}
