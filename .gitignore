# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Forge local-only artifacts (kept out of git) ---
.superpowers/
docs/
design/
mockup/*
!mockup/forge.html

# Cloned team repos (Spec 2 workspace root) — code on disk, never committed.
/.forge-workspace/

# Generated export files (Spec 8 export service) — on-disk hand-offs, never committed.
/.forge-exports/

# mma delegate worktrees (engine scratch, never commit) — repo-root only
/.mma/
